@{
    ViewData["Title"]      = "Announcement";
    ViewData["ActivePage"] = "Announcement";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="page-title">Announcement</div>

<!-- COMPOSE FORM -->
<div class="ann-compose mb-4">
    <div class="d-flex align-items-center gap-3 mb-3 flex-wrap">
        <div style="width:44px;height:44px;border-radius:50%;background:#4299e1;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:16px;flex-shrink:0;">A</div>
        <div style="font-size:15px;font-weight:700;flex:1;">Admin</div>
        <div style="display:flex;align-items:center;gap:8px;">
            <div style="background:rgba(40,167,69,0.15);border:1px solid rgba(40,167,69,0.4);border-radius:20px;padding:4px 14px;font-size:11px;font-weight:700;color:#68d391;"><i class="fas fa-circle me-1"></i>CEBU TECHNOLOGICAL UNIVERSITY OF GINATILAN</div>
        </div>
        <div class="position-relative" style="min-width:160px;">
            <select class="dark-input dark-select" id="ann-type" style="padding:8px 36px 8px 12px;font-size:12px;font-weight:700;">
                <option value="GENERAL">GENERAL</option>
                <option value="URGENT">URGENT</option>
                <option value="EVENT">EVENT</option>
                <option value="REMINDER">REMINDER</option>
            </select>
        </div>
    </div>

    <input type="text" class="dark-input mb-2" id="ann-title" placeholder="Title" />
    <textarea class="dark-input mb-3" id="ann-body" rows="3" placeholder="Write an announcement to student and Instructor....."></textarea>

    <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
        <div class="d-flex gap-3">
            <button style="background:none;border:none;color:var(--muted);font-size:18px;cursor:pointer;" title="Schedule"><i class="fas fa-calendar-alt"></i></button>
            <button style="background:none;border:none;color:var(--muted);font-size:18px;cursor:pointer;" title="Location"><i class="fas fa-map-marker-alt"></i></button>
        </div>
        <div class="d-flex align-items-center gap-3">
            <label style="display:flex;align-items:center;gap:8px;cursor:pointer;font-size:13px;color:var(--muted);">
                <input type="checkbox" id="pin-post" style="accent-color:var(--green);width:16px;height:16px;" />
                Pin post
            </label>
            <button class="btn-blue-sm" onclick="postAnnouncement()">Post Announcement</button>
        </div>
    </div>
</div>

<!-- FILTER TABS -->
<div class="d-flex gap-2 mb-4 flex-wrap">
    <button class="ann-filter-btn active" onclick="filterAnn('all',this)">ALL</button>
    <button class="ann-filter-btn" onclick="filterAnn('pinned',this)" style="border-color:rgba(66,153,225,0.4);color:#63b3ed;"><i class="fas fa-thumbtack me-1"></i>PINNED</button>
    <button class="ann-filter-btn" onclick="filterAnn('urgent',this)" style="border-color:rgba(229,62,62,0.4);color:#fc8181;">URGENT</button>
    <button class="ann-filter-btn" onclick="filterAnn('event',this)" style="border-color:rgba(40,167,69,0.4);color:#68d391;">EVENTS</button>
    <button class="ann-filter-btn" onclick="filterAnn('general',this)" style="border-color:rgba(128,90,213,0.4);color:#b794f4;">GENERAL</button>
</div>

<!-- ANNOUNCEMENTS LIST -->
<div id="ann-list">
    <!-- PINNED + URGENT -->
    <div class="ann-post-card" data-tag="pinned urgent">
        <div class="d-flex align-items-center justify-content-between mb-2 flex-wrap gap-2">
            <div class="d-flex align-items-center gap-10">
                <div style="width:38px;height:38px;border-radius:50%;background:#4299e1;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:14px;margin-right:10px;">A</div>
                <div>
                    <div style="font-weight:700;font-size:13px;">Admin</div>
                    <div style="font-size:11px;color:var(--muted);">System Administrator</div>
                </div>
            </div>
            <div class="d-flex align-items-center gap-2">
                <span class="ann-tag tag-pinned"><i class="fas fa-thumbtack me-1"></i>Pinned</span>
                <span class="ann-tag tag-urgent">Urgent</span>
                <span style="font-size:11px;color:var(--muted);">April 15, 2026</span>
            </div>
        </div>
        <div style="font-size:15px;font-weight:700;margin-bottom:8px;">Deadline for clearance submission — AY 2025-2026</div>
        <div style="font-size:13px;color:rgba(255,255,255,0.75);line-height:1.7;">
            All students are required to complete their clearance requirements on or before
            <span class="ann-highlight">April 30, 2026</span>. Incomplete submissions will not be processed.
            Please coordinate with your respective instructors immediately for any pending signatures.
        </div>
        <div class="d-flex justify-content-end gap-2 mt-3">
            <button class="btn-blue-sm" style="font-size:12px;padding:6px 16px;"><i class="fas fa-pen me-1"></i>Edit</button>
            <button class="btn-green-sm" style="background:var(--red);font-size:12px;padding:6px 16px;"><i class="fas fa-trash me-1"></i>Delete</button>
        </div>
    </div>

    <!-- URGENT -->
    <div class="ann-post-card" data-tag="urgent">
        <div class="d-flex align-items-center justify-content-between mb-2 flex-wrap gap-2">
            <div class="d-flex align-items-center gap-10">
                <div style="width:38px;height:38px;border-radius:50%;background:#4299e1;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:14px;margin-right:10px;">A</div>
                <div>
                    <div style="font-weight:700;font-size:13px;">Admin</div>
                    <div style="font-size:11px;color:var(--muted);">System Administrator</div>
                </div>
            </div>
            <div class="d-flex align-items-center gap-2">
                <span class="ann-tag tag-urgent">Urgent</span>
                <span style="font-size:11px;color:var(--muted);">April 15, 2026</span>
            </div>
        </div>
        <div style="font-size:15px;font-weight:700;margin-bottom:8px;">Attention Students! Clearance Must Be Completed</div>
        <div style="font-size:13px;color:rgba(255,255,255,0.75);line-height:1.7;">
            All students must secure a cleared status before enrollment for
            <span class="ann-highlight">AY 2026-2027</span>. Incomplete clearance may result in enrollment restrictions,
            so process your requirements as soon as possible.
        </div>
        <div class="d-flex justify-content-end gap-2 mt-3">
            <button class="btn-blue-sm" style="font-size:12px;padding:6px 16px;"><i class="fas fa-pen me-1"></i>Edit</button>
            <button class="btn-green-sm" style="background:var(--red);font-size:12px;padding:6px 16px;"><i class="fas fa-trash me-1"></i>Delete</button>
        </div>
    </div>

    <!-- EVENT -->
    <div class="ann-post-card" data-tag="event">
        <div class="d-flex align-items-center justify-content-between mb-2 flex-wrap gap-2">
            <div class="d-flex align-items-center gap-10">
                <div style="width:38px;height:38px;border-radius:50%;background:#4299e1;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:14px;margin-right:10px;">A</div>
                <div>
                    <div style="font-weight:700;font-size:13px;">Admin</div>
                    <div style="font-size:11px;color:var(--muted);">System Administrator</div>
                </div>
            </div>
            <div class="d-flex align-items-center gap-2">
                <span class="ann-tag tag-event">Event</span>
                <span style="font-size:11px;color:var(--muted);">April 15, 2026</span>
            </div>
        </div>
        <div style="font-size:15px;font-weight:700;margin-bottom:8px;">Enrollment for AY 2026-2027 opens May 5</div>
        <div style="font-size:13px;color:rgba(255,255,255,0.75);line-height:1.7;">
            Online enrollment for the next academic year will begin on <span class="ann-highlight">May 5, 2026</span>.
            Students must have a cleared status to proceed. Make sure all clearance requirements are settled before the enrollment window opens.
        </div>
        <div class="d-flex justify-content-end gap-2 mt-3">
            <button class="btn-blue-sm" style="font-size:12px;padding:6px 16px;"><i class="fas fa-pen me-1"></i>Edit</button>
            <button class="btn-green-sm" style="background:var(--red);font-size:12px;padding:6px 16px;"><i class="fas fa-trash me-1"></i>Delete</button>
        </div>
    </div>
</div>

@section Scripts {
<script>
function filterAnn(tag, btn) {
    document.querySelectorAll('.ann-filter-btn').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    document.querySelectorAll('#ann-list .ann-post-card').forEach(c => {
        c.style.display = tag==='all' ? '' : (c.dataset.tag||'').includes(tag) ? '' : 'none';
    });
}
function postAnnouncement() {
    const title = document.getElementById('ann-title').value.trim();
    const body  = document.getElementById('ann-body').value.trim();
    const type  = document.getElementById('ann-type').value.toLowerCase();
    const pinned= document.getElementById('pin-post').checked;
    if (!title || !body) { alert('Please enter a title and body.'); return; }

    const tagMap = { general:'tag-general', urgent:'tag-urgent', event:'tag-event', reminder:'tag-reminder' };
    const pin = pinned ? `<span class="ann-tag tag-pinned me-1"><i class="fas fa-thumbtack me-1"></i>Pinned</span>` : '';
    const html = `
    <div class="ann-post-card" data-tag="${type}${pinned?' pinned':''}">
        <div class="d-flex align-items-center justify-content-between mb-2 flex-wrap gap-2">
            <div class="d-flex align-items-center gap-10">
                <div style="width:38px;height:38px;border-radius:50%;background:#4299e1;display:flex;align-items:center;justify-content:center;font-weight:800;font-size:14px;margin-right:10px;">A</div>
                <div><div style="font-weight:700;font-size:13px;">Admin</div><div style="font-size:11px;color:var(--muted);">System Administrator</div></div>
            </div>
            <div class="d-flex align-items-center gap-2">
                ${pin}<span class="ann-tag ${tagMap[type]}">${type.toUpperCase()}</span>
                <span style="font-size:11px;color:var(--muted);">${new Date().toLocaleDateString('en-US',{month:'long',day:'numeric',year:'numeric'})}</span>
            </div>
        </div>
        <div style="font-size:15px;font-weight:700;margin-bottom:8px;">${title}</div>
        <div style="font-size:13px;color:rgba(255,255,255,0.75);line-height:1.7;">${body}</div>
        <div class="d-flex justify-content-end gap-2 mt-3">
            <button class="btn-blue-sm" style="font-size:12px;padding:6px 16px;"><i class="fas fa-pen me-1"></i>Edit</button>
            <button class="btn-green-sm" style="background:var(--red);font-size:12px;padding:6px 16px;" onclick="this.closest('.ann-post-card').remove()"><i class="fas fa-trash me-1"></i>Delete</button>
        </div>
    </div>`;
    document.getElementById('ann-list').insertAdjacentHTML('afterbegin', html);
    document.getElementById('ann-title').value = '';
    document.getElementById('ann-body').value  = '';
    document.getElementById('pin-post').checked = false;
}
</script>
}
