@model OnlineClearance.Models.RegisterViewModel
@{
    ViewData["Title"] = "Register";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Register – Online Clearance</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
    <link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet"/>
    <style>
        * { box-sizing: border-box; margin: 0; padding: 0; }
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background: url('/images/ctu-g.jpg') no-repeat center center;
            background-size: cover;
            display: flex; align-items: center;
            justify-content: center; padding: 24px 0;
        }
        .auth-frame {
            width: 900px; display: flex;
            border-radius: 10px; overflow: hidden;
            box-shadow: 0 20px 60px rgba(0,0,0,0.5);
        }
        .auth-left {
            width: 40%; background: #1a4731;
            display: flex; flex-direction: column;
            align-items: center; justify-content: center;
            padding: 48px 32px; text-align: center; gap: 18px;
        }
        .logo-circle {
            width: 72px; height: 72px; border-radius: 50%;
            background: #c9a84c;
            display: flex; align-items: center; justify-content: center;
            font-size: 26px; font-weight: 900; color: #1a4731;
            border: 3px solid rgba(255,255,255,0.25);
        }
        .auth-left h2 {
            font-size: 17px; font-weight: 700;
            color: white; line-height: 1.4;
        }
        .auth-left p {
            font-size: 12px; color: rgba(255,255,255,0.6);
            line-height: 1.6;
        }
        .notice-box {
            background: rgba(255,255,255,0.1);
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: 8px; padding: 12px 16px;
            font-size: 12px; color: rgba(255,255,255,0.85);
            line-height: 1.6; text-align: left;
        }
        .notice-box strong { color: #c9a84c; }
        .auth-right {
            flex: 1; background: white;
            padding: 40px 44px;
            display: flex; flex-direction: column;
            justify-content: center; position: relative;
        }
        .back-link {
            position: absolute; top: 18px; left: 22px;
            font-size: 13px; color: #555;
            text-decoration: none; font-weight: 500;
        }
        .back-link:hover { color: #1a4731; }
        .auth-title {
            font-size: 21px; font-weight: 800;
            color: #1a1a2e; margin-bottom: 4px;
            margin-top: 22px;
        }
        .auth-sub {
            font-size: 13px; color: #888;
            margin-bottom: 22px; line-height: 1.5;
        }
        .form-label-sm {
            font-size: 12px; font-weight: 600;
            color: #444; margin-bottom: 4px; display: block;
        }
        .req { color: #dc3545; }
        .form-input {
            width: 100%; border: 1px solid #d1d5db;
            border-radius: 6px; padding: 10px 13px;
            font-size: 13px; font-family: inherit;
            color: #1a1a2e; outline: none;
            transition: border-color 0.2s, box-shadow 0.2s;
        }
        .form-input:focus {
            border-color: #1a4731;
            box-shadow: 0 0 0 3px rgba(26,71,49,0.1);
        }
        .field-error {
            font-size: 11px; color: #dc3545;
            margin-top: 3px; display: block;
        }
        .alert-danger-sm {
            background: #fff5f5; border: 1px solid #f5c2c7;
            border-radius: 6px; padding: 10px 14px;
            font-size: 13px; color: #842029; margin-bottom: 14px;
        }
        .btn-register {
            width: 100%; background: #28a745; color: white;
            border: none; border-radius: 6px; padding: 12px;
            font-size: 14px; font-weight: 700;
            cursor: pointer; font-family: inherit;
            transition: background 0.2s; margin-top: 20px;
        }
        .btn-register:hover { background: #218838; }
        @@media (max-width: 640px) {
            .auth-frame { flex-direction: column; width: 98vw; }
            .auth-left  { width: 100%; padding: 28px; }
            .auth-right { padding: 28px; }
        }
    </style>
</head>
<body>
<div class="auth-frame">

    <!-- LEFT -->
    <div class="auth-left">
        <div class="logo-circle">
            <img src="/images/CTUG-logo-transparent.png" alt="Logo" style="width:100%; height:100%; object-fit:cover;">
        </div>
        <h2>Cebu Technological University - Ginatilan Extension Campus – Online Clearance</h2>
        <p>Create your account to get started.<br/>
           Your access will be activated by the Admin.</p>

        <div class="notice-box">
            <strong>Note:</strong> After registering, your account
            will be reviewed by the Admin who will assign your role
            (Student or Instructor) and activate your account.
            You will not be able to log in until your account
            is activated.
        </div>
    </div>

    <!-- RIGHT -->
    <div class="auth-right">
        <a href="/Home/Login" class="back-link">← Back to Login</a>

        <div class="auth-title">Create Account</div>
        <p class="auth-sub">
            Fill in your information below to register.
            The Admin will assign your role after registration.
        </p>

        @if (!ViewData.ModelState.IsValid &&
             ViewData.ModelState.ErrorCount > 0)
        {
            <div class="alert-danger-sm">
                ⚠ Please correct the errors below.
            </div>
        }

        @if (!string.IsNullOrEmpty(ViewBag.ErrorMessage))
        {
            <div class="alert-danger-sm">
                ⚠ @ViewBag.ErrorMessage
            </div>
        }

        <form asp-action="Register" asp-controller="Home"
              method="post" novalidate>
            @Html.AntiForgeryToken()

            <div class="row g-3">

                <!-- Name row -->
                <div class="col-md-5">
                    <label class="form-label-sm">
                        First Name <span class="req">*</span>
                    </label>
                    <input asp-for="FirstName" class="form-input"
                           placeholder="First name" autofocus/>
                    <span asp-validation-for="FirstName"
                          class="field-error"></span>
                </div>
                <div class="col-md-2">
                    <label class="form-label-sm">M.I.</label>
                    <input asp-for="MiddleInitial" class="form-input"
                           placeholder="M.I." maxlength="3"/>
                </div>
                <div class="col-md-5">
                    <label class="form-label-sm">
                        Last Name <span class="req">*</span>
                    </label>
                    <input asp-for="LastName" class="form-input"
                           placeholder="Last name"/>
                    <span asp-validation-for="LastName"
                          class="field-error"></span>
                </div>

                <!-- ID Number -->
                <div class="col-12">
                    <label class="form-label-sm">
                        ID Number <span class="req">*</span>
                    </label>
                    <input asp-for="IdNumber" class="form-input"
                           placeholder="e.g. 2024-00001"/>
                    <span asp-validation-for="IdNumber"
                          class="field-error"></span>
                </div>

                <!-- Password -->
                <div class="col-md-6">
                    <label class="form-label-sm">
                        Password <span class="req">*</span>
                    </label>
                    <input asp-for="Password" class="form-input"
                           type="password"
                           placeholder="Min. 6 characters"
                           autocomplete="new-password"/>
                    <span asp-validation-for="Password"
                          class="field-error"></span>
                </div>
                <div class="col-md-6">
                    <label class="form-label-sm">
                        Confirm Password <span class="req">*</span>
                    </label>
                    <input asp-for="ConfirmPassword" class="form-input"
                           type="password"
                           placeholder="Repeat password"
                           id="cpw"
                           autocomplete="new-password"/>
                    <span asp-validation-for="ConfirmPassword"
                          class="field-error"></span>
                </div>

            </div>

            <button type="submit" class="btn-register">
                Register Account
            </button>
        </form>

        <p style="text-align:center;font-size:13px;
                  color:#888;margin-top:16px;">
            Already have an account? &nbsp;
            <a href="/Home/Login"
               style="color:#28a745;font-weight:700;
                      text-decoration:none;">
                Log in here
            </a>
        </p>
    </div>

</div>

<script>
document.querySelector('form').addEventListener('submit', function(e) {
    const pw  = document.querySelector('input[name="Password"]');
    const cpw = document.getElementById('cpw');
    if (pw && cpw && pw.value !== cpw.value) {
        cpw.style.borderColor = '#dc3545';
        e.preventDefault();
    } else if (cpw) {
        cpw.style.borderColor = '';
    }
});
</script>
</body>
</html>