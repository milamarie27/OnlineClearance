@{
    ViewData["Title"]      = "Dashboard";
    ViewData["ActivePage"] = "Dashboard";
    Layout = "~/Views/Shared/_InstructorLayout.cshtml";
}

<!-- WELCOME BANNER -->
<div class="d-flex align-items-start justify-content-between mb-4 flex-wrap gap-3">
    <div>
        <h4 style="font-size:22px;font-weight:800;color:#1a1a2e;">
            Welcome back, <span style="color:var(--green);">Doc. Glicerio A. Baguia!</span>
        </h4>
        <p style="font-size:13px;color:#888;margin:0;">Here's what's happening to your clearance today</p>
    </div>
    <div class="period-box" style="background:white;box-shadow:0 1px 4px rgba(0,0,0,0.07);">
        <div class="period-icon" style="background:#e6f4ea;">
            <i class="fas fa-calendar-alt" style="color:var(--green);"></i>
        </div>
        <div>
            <div class="period-label" style="color:#888;">Active Academic Period</div>
            <div class="period-value" style="color:var(--green);">A.Y. 2025-2026, 2nd Semester</div>
        </div>
        <span class="active-badge">Active</span>
    </div>
</div>

<!-- STAT CARDS -->
<div class="row g-3 mb-4">
    <div class="col-md-3 col-sm-6">
        <div class="stat-card">
            <div class="stat-icon blue"><i class="fas fa-chalkboard-teacher"></i></div>
            <div>
                <div class="stat-num">3</div>
                <div class="stat-label">Subject Assigned</div>
                <div class="stat-sub">Total Classes Assigned</div>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="stat-card">
            <div class="stat-icon green"><i class="fas fa-users"></i></div>
            <div>
                <div class="stat-num">50</div>
                <div class="stat-label">Total Students</div>
                <div class="stat-sub">Across all my subjects</div>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="stat-card">
            <div class="stat-icon teal"><i class="fas fa-check-circle"></i></div>
            <div>
                <div class="stat-num">26</div>
                <div class="stat-label">Cleared Students</div>
                <div class="stat-sub">Across all my subjects</div>
            </div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="stat-card">
            <div class="stat-icon orange"><i class="fas fa-clock"></i></div>
            <div>
                <div class="stat-num">24</div>
                <div class="stat-label">Pending Students</div>
                <div class="stat-sub">Across all my subjects</div>
            </div>
        </div>
    </div>
</div>

<!-- BOTTOM ROW: CHECKLIST + ANNOUNCEMENTS -->
<div class="row g-3">

    <!-- CLEARANCE CHECKLIST -->
    <div class="col-md-5">
        <div class="page-card">
            <div class="page-card-hd dark" style="display:flex;justify-content:space-between;align-items:center;">
                <span><i class="fas fa-tasks me-2"></i>Clearance Checklist</span>
                <span id="progress-badge" style="background:var(--green-accent);border-radius:20px;padding:3px 12px;font-size:11px;font-weight:700;">0/4 Completed</span>
            </div>
            <div class="checklist-item">
                <div class="check-box"><i class="fas fa-check"></i></div>
                <div>
                    <div class="check-title">Step 1: Upload E-Signature</div>
                    <div class="check-desc">Add your e-signature in your profile dashboard.</div>
                </div>
            </div>
            <div class="checklist-item">
                <div class="check-box"><i class="fas fa-check"></i></div>
                <div>
                    <div class="check-title">Step 2: Review Subject Requests</div>
                    <div class="check-desc">Approve or decline pending subject clearances.</div>
                </div>
            </div>
            <div class="checklist-item">
                <div class="check-box"><i class="fas fa-check"></i></div>
                <div>
                    <div class="check-title">Step 3: Review Organization Requests</div>
                    <div class="check-desc">Approve or decline organization/department requests.</div>
                </div>
            </div>
            <div class="checklist-item">
                <div class="check-box"><i class="fas fa-check"></i></div>
                <div>
                    <div class="check-title">Step 4: Final Review</div>
                    <div class="check-desc">Check all entries and make corrections if needed.</div>
                </div>
            </div>
        </div>
    </div>

    <!-- ANNOUNCEMENTS -->
    <div class="col-md-7">
        <div class="page-card">
            <div class="page-card-hd dark">
                <div class="ann-tabs" style="margin-bottom:0;">
                    <button class="ann-tab active" onclick="filterAnn('all', this)">ALL</button>
                    <button class="ann-tab" onclick="filterAnn('pinned', this)" style="background:var(--green);color:white;border-color:var(--green);">
                        <i class="fas fa-thumbtack me-1"></i>PINNED
                    </button>
                    <button class="ann-tab" onclick="filterAnn('urgent', this)" style="background:var(--red);color:white;border-color:var(--red);">URGENT</button>
                    <button class="ann-tab" onclick="filterAnn('event', this)" style="background:#0d6efd;color:white;border-color:#0d6efd;">EVENTS</button>
                </div>
            </div>

            <div id="ann-list" style="padding:16px;">
                <div class="ann-card mb-3" data-tag="pinned urgent">
                    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;">
                        <div style="display:flex;align-items:center;gap:10px;">
                            <div class="ann-avatar">SA</div>
                            <div>
                                <div style="font-weight:700;font-size:13px;">System Administrator</div>
                                <div style="font-size:11px;color:#888;">April 15, 2026</div>
                            </div>
                        </div>
                        <div class="d-flex gap-2">
                            <span class="ann-tag tag-pinned"><i class="fas fa-thumbtack me-1"></i>Pinned</span>
                            <span class="ann-tag tag-urgent">Urgent</span>
                        </div>
                    </div>
                    <div class="ann-title">Deadline for clearance submission — AY 2025-2026</div>
                    <div class="ann-body">
                        All students are required to complete their clearance requirements on or before
                        <span class="ann-highlight">April 30, 2026</span>. Incomplete submissions will not be processed.
                        Please coordinate with your respective instructors immediately for any pending signatures.
                    </div>
                </div>

                <div class="ann-card" data-tag="event">
                    <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:8px;">
                        <div style="display:flex;align-items:center;gap:10px;">
                            <div class="ann-avatar">SA</div>
                            <div>
                                <div style="font-weight:700;font-size:13px;">System Administrator</div>
                                <div style="font-size:11px;color:#888;">April 15, 2026</div>
                            </div>
                        </div>
                        <span class="ann-tag tag-event">Event</span>
                    </div>
                    <div class="ann-title">Enrollment for AY 2026-2027 opens May 5</div>
                    <div class="ann-body">
                        The new academic year will begin on <span class="ann-highlight">May 5, 2026</span>.
                        All students must complete their clearance before enrollment can proceed.
                    </div>
                </div>
            </div>
        </div>
    </div>

</div>

@section Scripts {
<script>
    // CHECKLIST TOGGLE
    document.querySelectorAll('.check-box').forEach(box => {
        box.addEventListener('click', () => {
            box.classList.toggle('active');
            updateProgress();
        });
    });

    function updateProgress() {
        const total   = document.querySelectorAll('.check-box').length;
        const checked = document.querySelectorAll('.check-box.active').length;
        document.getElementById('progress-badge').textContent = `${checked}/${total} Completed`;
    }

    updateProgress();

    // ANNOUNCEMENT FILTER
    function filterAnn(tag, btn) {
        document.querySelectorAll('.ann-tab').forEach(b => {
            b.style.background  = 'white';
            b.style.color       = '#555';
            b.style.borderColor = '#dee2e6';
        });
        btn.style.background  = '#28a745';
        btn.style.color       = 'white';
        btn.style.borderColor = '#28a745';

        document.querySelectorAll('#ann-list [data-tag]').forEach(card => {
            if (tag === 'all') {
                card.style.display = '';
            } else {
                const tags = card.getAttribute('data-tag') || '';
                card.style.display = tags.includes(tag) ? '' : 'none';
            }
        });
    }
</script>
}