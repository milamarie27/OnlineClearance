@model IEnumerable<OnlineClearance.Models.OrganizationRequest>
@{
    ViewData["Title"]      = "Organization";
    ViewData["ActivePage"] = "Organization";
    Layout = "~/Views/Shared/_InstructorLayout.cshtml";
}

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-3" role="alert">
        <i class="fas fa-check-circle me-2"></i>@TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex align-items-center justify-content-between mb-3">
    <h5 class="fw-bold mb-0" style="color:#1a1a2e;">Organization</h5>
    <span class="semester-badge"><i class="fas fa-calendar-alt me-2"></i>2nd Semester · A.Y. 2025-2026</span>
</div>

<div class="page-card">
    <div class="page-card-hd dark">
        <i class="fas fa-sitemap me-2"></i>ORGANIZATION
    </div>
    <div class="table-responsive">
        <table class="data-table">
            <thead>
                <tr>
                    <th style="width:80px;text-align:center;">NO.</th>
                    <th>POSITION</th>
                    <th>REQUESTED</th>
                    <th style="text-align:center;">ACTION</th>
                </tr>
            </thead>
            <tbody>
                @if (Model != null && Model.Any())
                {
                    int i = 1;
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td style="text-align:center;">
                                <span class="code-badge">@i.ToString("D2")</span>
                            </td>
                            <td style="font-weight:600;">@item.Position</td>
                            <td>
                                <div style="font-weight:600;font-size:13px;">@item.StudentName</div>
                                <div style="font-size:11px;color:#888;">@item.Course</div>
                            </td>
                            <td style="text-align:center;">
                                @if (item.Status == "Cleared")
                                {
                                    <span class="status-approved">Cleared</span>
                                }
                                else if (item.Status == "Declined")
                                {
                                    <span class="status-declined">Declined</span>
                                }
                                else
                                {
                                    <div class="d-flex gap-2 justify-content-center">
                                        <form asp-action="ApproveOrg" asp-controller="Instructor" method="post" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="btn-approve">
                                                <i class="fas fa-check me-1"></i>Cleared
                                            </button>
                                        </form>
                                        <form asp-action="DeclineOrg" asp-controller="Instructor" method="post" style="display:inline;">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@item.Id" />
                                            <button type="submit" class="btn-decline">
                                                <i class="fas fa-times me-1"></i>Declined
                                            </button>
                                        </form>
                                    </div>
                                }
                            </td>
                        </tr>
                        i++;
                    }
                }
                else
                {
                    @foreach (var row in new[] {
                        new { num=1, position="Campus Director", student="Althea Jean Barnes",  course="BSIT-2A", status="Cleared"  },
                        new { num=2, position="Campus Director", student="Mila Marie Villamor", course="BSIT-2A", status="Cleared"  },
                        new { num=3, position="Campus Director", student="Melanie Dinglasa",    course="BSIT-2A", status="Declined" },
                        new { num=4, position="Campus Director", student="Stephany Camoro",     course="BSIT-2A", status="None"    },
                        new { num=5, position="Campus Director", student="Janice Angel Chua",   course="BSIT-2A", status="None"    },
                        new { num=6, position="Campus Director", student="Leskha Lim",          course="BSIT-2A", status="None"    },
                        new { num=7, position="Campus Director", student="Gabriel Tolomea",     course="BSIT-2A", status="None"    },
                        new { num=8, position="Campus Director", student="Alex Belongilot",     course="BSIT-2A", status="None"    },
                        new { num=9, position="Campus Director", student="Sheena Melgar",       course="BSIT-2A", status="None"    },
                    })
                    {
                        <tr>
                            <td style="text-align:center;">
                                <span class="code-badge">@row.num.ToString("D2")</span>
                            </td>
                            <td style="font-weight:600;">@row.position</td>
                            <td>
                                <div style="font-weight:600;font-size:13px;">@row.student</div>
                                <div style="font-size:11px;color:#888;">@row.course</div>
                            </td>
                            <td style="text-align:center;">
                                @if (row.status == "Cleared")
                                {
                                    <span class="status-approved">Cleared</span>
                                }
                                else if (row.status == "Declined")
                                {
                                    <span class="status-declined">Declined</span>
                                }
                                else
                                {
                                    <div class="d-flex gap-2 justify-content-center">
                                        <button class="btn-approve" onclick="handleAction(this,'cleared')">
                                            <i class="fas fa-check me-1"></i>Cleared
                                        </button>
                                        <button class="btn-decline" onclick="handleAction(this,'declined')">
                                            <i class="fas fa-times me-1"></i>Declined
                                        </button>
                                    </div>
                                }
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
    function handleAction(btn, action) {
        const actionCell = btn.closest('td');
        if (action === 'cleared') {
            actionCell.innerHTML = '<span class="status-approved">Cleared</span>';
        } else {
            actionCell.innerHTML = '<span class="status-declined">Declined</span>';
        }
    }
</script>
}