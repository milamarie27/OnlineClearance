@model OnlineClearance.Models.StudentProfileViewModel

@{
    ViewData["Title"]      = "Profile";
    ViewData["ActivePage"] = "Profile";
    Layout = "~/Views/Shared/_StudentLayout.cshtml";
}

@if (TempData["ProfileSaved"] != null)
{
    <div class="alert alert-success alert-dismissible fade show mb-3">
        <i class="fas fa-check-circle me-2"></i>@TempData["ProfileSaved"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- PROFILE HEADER CARD -->
<div style="background:var(--green);border-radius:12px;padding:22px 28px;display:flex;align-items:center;gap:20px;margin-bottom:20px;">
    <div style="position:relative;">
        <div style="width:70px;height:70px;border-radius:50%;background:white;display:flex;align-items:center;justify-content:center;cursor:pointer;" onclick="document.getElementById('avatar-upload').click()">
            <i class="fas fa-user" style="color:#1a4731;font-size:28px;"></i>
        </div>
        <div style="position:absolute;bottom:0;right:0;background:var(--green-accent);border-radius:50%;width:22px;height:22px;display:flex;align-items:center;justify-content:center;cursor:pointer;" onclick="document.getElementById('avatar-upload').click()">
            <i class="fas fa-camera" style="color:white;font-size:10px;"></i>
        </div>
        <input type="file" id="avatar-upload" accept="image/*" style="display:none;" />
    </div>
    <div>
        <div style="font-size:20px;font-weight:800;color:white;">@(Model?.FullName ?? "Althea Jean Barnes")</div>
        <div style="font-size:13px;color:rgba(255,255,255,0.7);">Student ID: @(Model?.StudentId ?? "1239477509")</div>
    </div>
    <div style="margin-left:auto;">
        <span style="background:var(--green-accent);color:white;border-radius:8px;padding:8px 20px;font-size:13px;font-weight:700;">Active</span>
    </div>
</div>

<!-- EDIT FORM -->
<div style="background:white;border-radius:12px;padding:28px;box-shadow:0 1px 4px rgba(0,0,0,0.07);">
    <form asp-action="SaveProfile" asp-controller="Student" method="post" novalidate>
        @Html.AntiForgeryToken()

        <div class="row g-3">
            <!-- First Name -->
            <div class="col-md-6">
                <label class="profile-label">First Name</label>
                <div class="profile-input-wrap">
                    <input asp-for="FirstName" class="profile-input" placeholder="First Name" />
                    <i class="fas fa-pen profile-edit-icon"></i>
                </div>
            </div>
            <!-- Student ID (readonly) -->
            <div class="col-md-6">
                <label class="profile-label">Student ID</label>
                <div class="profile-input-wrap">
                    <input asp-for="StudentId" class="profile-input" readonly style="background:#f8f9fa;cursor:not-allowed;" />
                </div>
            </div>
            <!-- Middle Initial -->
            <div class="col-md-6">
                <label class="profile-label">Middle Initial</label>
                <div class="profile-input-wrap">
                    <input asp-for="MiddleInitial" class="profile-input" placeholder="M.I." maxlength="3" />
                    <i class="fas fa-pen profile-edit-icon"></i>
                </div>
            </div>
            <!-- Course -->
            <div class="col-md-6">
                <label class="profile-label">Course</label>
                <div class="profile-input-wrap select-wrap">
                    <select asp-for="Course" class="profile-input">
                        <option value="BSIT">Bachelor of Science in IT</option>
                        <option value="BSCS">Bachelor of Science in CS</option>
                        <option value="BSIS">Bachelor of Science in IS</option>
                        <option value="BSED">Bachelor of Science in Education</option>
                    </select>
                    <i class="fas fa-chevron-down profile-edit-icon"></i>
                </div>
            </div>
            <!-- Last Name -->
            <div class="col-md-6">
                <label class="profile-label">Last Name</label>
                <div class="profile-input-wrap">
                    <input asp-for="LastName" class="profile-input" placeholder="Last Name" />
                    <i class="fas fa-pen profile-edit-icon"></i>
                </div>
            </div>
            <!-- Year Level -->
            <div class="col-md-6">
                <label class="profile-label">Year Level</label>
                <div class="profile-input-wrap select-wrap">
                    <select asp-for="YearLevel" class="profile-input">
                        <option value="1st Year">1st Year</option>
                        <option value="2nd Year">2nd Year</option>
                        <option value="3rd Year">3rd Year</option>
                        <option value="4th Year">4th Year</option>
                    </select>
                    <i class="fas fa-chevron-down profile-edit-icon"></i>
                </div>
            </div>
            <!-- Suffix -->
            <div class="col-md-6">
                <label class="profile-label">Suffix Name</label>
                <div class="profile-input-wrap">
                    <input asp-for="Suffix" class="profile-input" placeholder="e.g. Jr., Sr., III" />
                    <i class="fas fa-pen profile-edit-icon"></i>
                </div>
            </div>
            <!-- Section -->
            <div class="col-md-6">
                <label class="profile-label">Section</label>
                <div class="profile-input-wrap select-wrap">
                    <select asp-for="Section" class="profile-input">
                        <option value="2A">2A</option>
                        <option value="2B">2B</option>
                        <option value="3A">3A</option>
                        <option value="3B">3B</option>
                    </select>
                    <i class="fas fa-chevron-down profile-edit-icon"></i>
                </div>
            </div>
            <!-- Username -->
            <div class="col-md-6">
                <label class="profile-label">Username</label>
                <div class="profile-input-wrap">
                    <input asp-for="Username" class="profile-input" placeholder="Username" />
                    <i class="fas fa-pen profile-edit-icon"></i>
                </div>
            </div>
            <!-- Password -->
            <div class="col-md-6">
                <label class="profile-label">Account Password</label>
                <div class="profile-input-wrap">
                    <input asp-for="Password" class="profile-input" type="password" placeholder="••••••••••••••••" id="pw-field" />
                    <i class="fas fa-eye-slash profile-edit-icon" id="pw-toggle" onclick="togglePw()" style="cursor:pointer;"></i>
                </div>
            </div>
        </div>

        <div style="margin-top:24px;text-align:center;">
            <button type="submit" class="btn-green" style="padding:12px 64px;font-size:15px;letter-spacing:1px;">
                SAVE
            </button>
        </div>
    </form>
</div>

@section Styles {
<style>
    .profile-label { font-size: 11px; font-weight: 700; color: #555; margin-bottom: 5px; display: block; letter-spacing: 0.3px; }
    .profile-input-wrap { position: relative; }
    .profile-input {
        width: 100%; border: 1px solid #d1d5db; border-radius: 8px;
        padding: 10px 36px 10px 13px; font-size: 13px;
        font-family: inherit; color: #1a1a2e; outline: none;
        transition: border-color 0.2s, box-shadow 0.2s;
        background: white; appearance: none;
    }
    .profile-input:focus { border-color: #1a4731; box-shadow: 0 0 0 3px rgba(26,71,49,0.1); }
    .profile-edit-icon { position: absolute; right: 12px; top: 50%; transform: translateY(-50%); color: #aaa; font-size: 12px; pointer-events: none; }
    .select-wrap .profile-edit-icon { pointer-events: none; }
</style>
}

@section Scripts {
<script>
function togglePw() {
    const f = document.getElementById('pw-field');
    const icon = document.getElementById('pw-toggle');
    if (f.type === 'password') { f.type = 'text';     icon.className = 'fas fa-eye profile-edit-icon'; }
    else                        { f.type = 'password'; icon.className = 'fas fa-eye-slash profile-edit-icon'; }
    icon.style.cursor = 'pointer';
}
</script>
}
